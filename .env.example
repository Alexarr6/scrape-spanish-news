# Optional local Postgres settings for docker compose / Make targets.
# Copy to .env if you want to override the boring defaults.
# You can also set DATABASE_URL here for local persistence work.
# DATABASE_URL=postgresql://spain_news:spain_news_dev@127.0.0.1:5433/spain_news_bias
# OPENAI_API_KEY=sk-...
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-5-mini
# LLM_BASE_URL=
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_RETRIES=2
# LLM_PROMPT_VERSION=v1
#
# Backward-compatible provider-specific vars still supported:
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=minimax/minimax-m2.7
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LOCAL_DB_PORT=5433
LOCAL_DB_NAME=spain_news_bias
LOCAL_DB_USER=spain_news
LOCAL_DB_PASSWORD=spain_news_dev
