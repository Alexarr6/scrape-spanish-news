{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "comparison_summary.v1",
  "title": "Comparison Summary v1",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "date",
    "baseline_ref",
    "current_ref",
    "status",
    "warnings",
    "sources"
  ],
  "properties": {
    "schema_version": { "const": "comparison_summary.v1" },
    "generated_at": { "type": "string", "minLength": 1 },
    "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "baseline_ref": { "type": "string", "minLength": 1 },
    "current_ref": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ok", "warning", "invalid"] },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source",
          "baseline_count",
          "current_count",
          "delta_abs",
          "delta_pct",
          "status",
          "warnings",
          "metrics"
        ],
        "properties": {
          "source": { "type": "string", "minLength": 1 },
          "baseline_count": { "type": "integer", "minimum": 0 },
          "current_count": { "type": "integer", "minimum": 0 },
          "delta_abs": { "type": "integer" },
          "delta_pct": { "type": "number" },
          "status": { "enum": ["ok", "warning", "invalid"] },
          "warnings": { "type": "array", "items": { "type": "string" } },
          "metrics": {
            "type": "object",
            "required": ["discovered", "processed", "kept", "discarded_by_date", "stop_reason"],
            "properties": {
              "discovered": { "type": "integer", "minimum": 0 },
              "processed": { "type": "integer", "minimum": 0 },
              "kept": { "type": "integer", "minimum": 0 },
              "discarded_by_date": { "type": "integer", "minimum": 0 },
              "stop_reason": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
